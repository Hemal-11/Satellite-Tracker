# ============================================
# frontend/.env.example
# Copy this file to frontend/.env.local and fill
# in real values. NEVER commit .env.local.
# ============================================

# Backend API base URL (leave empty to use Vite proxy in development)
VITE_API_BASE=

# Cesium Ion access token (required for Cesium terrain/imagery assets)
# Get yours at: https://cesium.com/ion/tokens
VITE_CESIUM_TOKEN=your_cesium_ion_token_here
